# Copy this file to .env (gitignored) or export the vars directly.
# Required: a GitHub owner (user or org) whose public repos we project.
GITHUB_OWNER=

# Optional but strongly recommended. A GitHub PAT (classic `public_repo`
# or fine-grained with read access). Without a token, unauthenticated
# GitHub REST calls are rate-limited to 60/hour.
GITHUB_TOKEN=
